PORT=5000
NODE_ENV=development
# Option A: single connection string (preferred for hosted Postgres)
DATABASE_URL=

# Option B: split DB config (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=interndb
DB_USER=postgres
DB_PASSWORD=yourpassword

# Redis (set REDIS_ENABLED=true when Redis is running)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d
